SHELL=/bin/bash
PATH=/usr/local/sbin:/usr/local/bin:/sbin:/bin:/usr/sbin:/usr/bin
CRON_TZ=Europe/Moscow

# Общие настройки: 
# Используем ionice -c 3 (запуск только когда диск свободен) 
# и nice -n 19 (самый низкий приоритет для процессора).

# Работа с файловой системой:
0 1 * * * nice -n 19 ionice -c 3 /usr/local/bin/python /app/manage.py delete_unknown_files >> /app/logs/cron/cron.log 2>&1
30 2 * * * nice -n 19 ionice -c 3 /usr/local/bin/python /app/manage.py delete_irrelevant_files >> /app/logs/cron/cron.log 2>&1
0 4 * * * nice -n 19 ionice -c 3 /usr/local/bin/python /app/manage.py cleanup_users_avatars >> /app/logs/cron/cron.log 2>&1

# Удаление не актуальных данных:
15 3 * * * nice -n 19 ionice -c 3 /usr/local/bin/python /app/manage.py cleanup_notifications >> /app/logs/cron/cron.log 2>&1
30 4 * * * nice -n 15 ionice -c 2 /usr/local/bin/python /app/manage.py cleanup_irrelevant_cell_measure >> /app/logs/cron/cron.log 2>&1

# Обновление данных:
# Добавляем небольшую задержку (sleep), чтобы не стартовать ровно в 00 секунд вместе с другими системными задачами
*/30 * * * * sleep 15 && nice -n 15 /usr/local/bin/python /app/manage.py update_data_from_ts >> /app/logs/cron/cron.log 2>&1
45 3 * * * sleep 10 && nice -n 15 ionice -c 2 -n 7 /usr/local/bin/python /app/manage.py import_mqtt_2_db >> /app/logs/cron/cron.log 2>&1
45 11 * * * sleep 10 && nice -n 15 ionice -c 2 -n 7 /usr/local/bin/python /app/manage.py import_mqtt_2_db >> /app/logs/cron/cron.log 2>&1
45 19 * * * sleep 10 && nice -n 15 ionice -c 2 -n 7 /usr/local/bin/python /app/manage.py import_mqtt_2_db >> /app/logs/cron/cron.log 2>&1

# Резервное копирование:
# Сдвигаем на 45-ю минуту, чтобы не пересекаться с началом часа, когда срабатывают многие скрипты
45 */6 * * * nice -n 10 ionice -c 2 -n 7 /usr/local/bin/python /app/manage.py database_backup >> /app/logs/cron/cron.log 2>&1

# Повторная отправка "зависших" писем (не чаще чем 2 минуты)
*/5 * * * * nice -n 19 ionice -c 3 /usr/local/bin/python /app/manage.py resend_stuck_emails >> /app/logs/cron/cron.log 2>&1
